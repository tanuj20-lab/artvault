# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Environment files — NEVER commit real secrets
.env
.env.local
.env.production
server/.env
client/.env

# Build output
client/dist/
client/build/

# Uploads (user-uploaded files — not tracked in git)
server/uploads/*
!server/uploads/.gitkeep

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
