# ArtVault — Environment Variables (Production)
# Copy these values to Render Dashboard > Environment Variables

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get this from: Atlas > Cluster > Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/art-gallery-auction?retryWrites=true&w=majority

# JWT — use a strong random secret in production
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRE=30d

# Your Vercel frontend URL (set AFTER deploying to Vercel)
CLIENT_URL=https://your-app.vercel.app
